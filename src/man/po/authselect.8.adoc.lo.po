msgstr "*-c, --smartcard-auth*"

#. type: Plain text
#: src/man/authselect.8.adoc:133
#, no-wrap
msgid "Print smartcard-auth content.\n"
msgstr "ສະແດງເນື້ອໃນຂອງ smartcard-auth.\n"

#. type: Labeled list
#: src/man/authselect.8.adoc:134
#, no-wrap
