#: src/lib/authselect.c:47 src/lib/authselect.c:188
msgid "Unable to obtain supported features"
msgstr "ບໍ່ສາມາດດຶງຂໍ້ມູນຄຸນສົມບັດທີ່ຮອງຮັບໄດ້"

