msgstr "ອັບເດດໄຟລ໌ການຕັ້ງຄ່າທັງໝົດ"

#: src/compat/authcompat_Options.py:126 src/compat/authcompat_Options.py:127
msgid "the same as --updateall"
msgstr "ຄືກັນກັບ --updateall"

